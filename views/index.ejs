<!DOCTYPE html>
<html lang="en">
<head>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mini Message Board</title>
   <link rel="stylesheet" href="/styles.css">
</head>
<body>
 
    
    <div class="header">
        <i 
        id="showDialogButton"
        class="fa fa-comments fa-2x" aria-hidden="true" 
        style="
        size: 16;
        color: lightskyblue; 
        cursor: pointer"></i>
    </div>
    <div class="container">
      <div class="sidebar">
        
      </div>
      <div class="messageContainer">
      
          <% messages.map((message) => { %>
            <div class="message">
               <p><%= message.text%></p>
            </div>
                
           <% }) %>
       
      </div>
      <dialog id="myDialog">
        <h1>Fuck off</h1>
      </dialog>
    </div>  
 
  <script src="/script.js"></script>
</body>
</html>